# Qwen LLM API Configuration

# API mode: cloud = DashScope API, local = local vLLM deployment
API_MODE=cloud

# DashScope API key (obtain from https://dashscope.console.aliyun.com/)
DASHSCOPE_API_KEY=your-api-key-here

# Optional: select model
# qwen-plus: balanced performance and cost, suitable for daily use
# qwen-turbo: fast inference, low cost
# qwen-max: maximum capability, highest cost
QWEN_MODEL=qwen-plus
